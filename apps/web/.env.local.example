# ─── API Backend ─────────────────────────────────────────────────────────────
# Em produção: URL do Cloud Run
NEXT_PUBLIC_API_URL=http://localhost:8080

# ─── Site ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://pdfrápido.com.br

# ─── Google AdSense ───────────────────────────────────────────────────────────
# Obtenha em: AdSense → Anúncios → Por unidade de anúncio
NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXXX

# Slots individuais (criar um para cada posição no AdSense)
NEXT_PUBLIC_AD_SLOT_HEADER=0000000001    # Banner acima do hero
NEXT_PUBLIC_AD_SLOT_ARTICLE=0000000002  # In-article na homepage
NEXT_PUBLIC_AD_SLOT_FOOTER=0000000003   # Final da página
NEXT_PUBLIC_AD_SLOT_TOOL_TOP=0000000004 # Acima da ferramenta
NEXT_PUBLIC_AD_SLOT_TOOL_MID=0000000005 # Meio da ferramenta
NEXT_PUBLIC_AD_SLOT_TOOL_BOTTOM=0000000006 # Final da ferramenta

# ─── Google Search Console ───────────────────────────────────────────────────
NEXT_PUBLIC_GSC_VERIFICATION=cole-seu-codigo-de-verificacao-aqui
